# Copy this file to `.env` to override defaults.
# These variables are read by Vite at build / dev time.

# Where the frontend should call the backend.
# Leave empty to use the smart fallback (localhost on dev, page host on LAN).
# Set to your deployed backend URL in production.
#
# Examples:
#   VITE_API_URL=http://192.168.1.10:5000              # specific LAN IP
#   VITE_API_URL=https://my-ems-api.onrender.com       # deployed backend
VITE_API_URL=
