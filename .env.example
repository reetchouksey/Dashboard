# Copy this file to `.env` to override defaults.
# These variables are read by Vite at build / dev time.

# Where the frontend should call the backend.
#
# Leave empty to use the built-in smart fallback chain:
#   - localhost dev      -> http://localhost:5000
#   - LAN dev (phone)    -> http://<your-lan-ip>:5000
#   - same-origin prod   -> the page's own origin (Render single-service)
#   - any other prod     -> the hardcoded Render URL in src/services/api.js
#
# Set this only if you've deployed YOUR OWN backend somewhere else and want
# the Vercel / static frontend to talk to it instead.
#
# Examples:
#   VITE_API_URL=http://192.168.1.10:5000              # specific LAN IP
#   VITE_API_URL=https://my-ems-api.onrender.com       # custom deployed backend
VITE_API_URL=
