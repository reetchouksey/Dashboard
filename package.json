{
  "name": "employee-management-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Modern Employee Management Dashboard built with React + Redux Toolkit",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server/server.cjs",
    "server:json": "json-server --watch db.json --port 5000",
    "db:view": "node server/view-db.cjs",
    "start": "concurrently \"npm run server\" \"npm run dev\""
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.2.7",
    "axios": "^1.7.7",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.3.0",
    "react-redux": "^9.1.2",
    "react-router-dom": "^6.26.2",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "json-server": "^0.17.4",
    "vite": "^5.4.6"
  }
}
